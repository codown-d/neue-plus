{
  "private": true,
  "name": "neue",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm -C play dev",
    "update:version": "tsx scripts/update-version.ts",
    "clean": "pnpm run clean:dist && pnpm run -r --parallel clean",
    "clean:dist": "rimraf dist",
    "build": "pnpm run -C internal/build start",
    "build:theme": "pnpm run -C packages/theme-chalk build",
    "format": "prettier --write --cache .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache",
    "lint:fix": "pnpm run lint --fix",
    "lint:commit": "commitlint",
    "docs:dev": "pnpm run -C docs dev",
    "docs:build": "pnpm run -C docs build",
    "docs:serve": "pnpm run -C docs serve",
    "prepare": "husky",
    "gen:version": "tsx scripts/gen-version.ts",
    "stub": "pnpm run -r --parallel stub",
    "postinstall": "pnpm stub && concurrently \"pnpm gen:version\""
  },
  "workspaces": [
    "packages/*",
    "play",
    "docs"
  ],
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "vite-plugin-vue-devtools": "^7.7.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.3",
    "@element-plus/icons-vue": "^2.3.1",
    "@neue-plus/components": "workspace:*",
    "@neue-plus/constants": "workspace:*",
    "@neue-plus/directives": "workspace:*",
    "@neue-plus/hooks": "workspace:*",
    "@neue-plus/theme-chalk": "workspace:*",
    "@neue-plus/utils": "workspace:*",
    "concurrently": "^7.2.2",
    "element-plus": "^2.9.9",
    "husky": "^9.1.7",
    "typescript": "~5.8.0",
    "vite": "^6.2.5",
    "vitepress": "^1.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx,md,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
